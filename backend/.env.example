# ================================
# TruckLink Backend — Environment
# ================================

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://trucklink:trucklink123@localhost:5432/trucklink

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Platform Settings
PLATFORM_FEE_PERCENT=12
VAT_PERCENT=18
ESCROW_HOLD_HOURS=48
MATCHING_RADIUS_KM=30
MATCHING_TIMEOUT_SEC=90
OTP_EXPIRY_MIN=5

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=trucklink-uploads
AWS_S3_URL_EXPIRY=3600

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVER_KEY=your-firebase-server-key

# Vonage SMS
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret

# Tranzilla (Israeli Payment)
TRANZILLA_TERMINAL=your-terminal-id
TRANZILLA_PASSWORD=your-terminal-password
